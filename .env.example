# Copy this to `.env` and fill in your values

# MongoDB Atlas connection string (include database user/password if needed)
MONGODB_URI="mongodb+srv://YOUR_USER:YOUR_PASS@YOUR_CLUSTER.mongodb.net/?retryWrites=true&w=majority"
MONGODB_DB="class_awards"
MONGODB_COLLECTION="state"

# Admin password for locking phases (do not reuse real passwords)
ADMIN_PASSWORD="awards2025"

# Frontend origin(s) allowed to call the API (comma-separated).
# Use "*" for local dev, but lock it down for real deployments.
CORS_ORIGINS="*"

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com